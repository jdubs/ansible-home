{
  "apiVersion": "dashboard.grafana.app/v1",
  "kind": "Dashboard",
  "metadata": {
    "name": "connection-monitor"
  },
  "spec": {
    "annotations": { "list": [] },
    "description": "Monitors Spectrum (VLAN 1) and ATT (VLAN 15) internet connectivity with automatic failover detection",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "links": [],
    "panels": [
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "id": 100,
        "title": "Connection Status",
        "type": "row"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
            "mappings": [{ "options": { "0": { "color": "green", "text": "UP" }, "1": { "color": "red", "text": "DOWN" } }, "type": "value" }]
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "id": 1,
        "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "1 - probe_success{job=\"blackbox-spectrum\"}", "legendFormat": "", "refId": "A" }],
        "title": "Spectrum (VLAN 1)",
        "type": "stat"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
            "mappings": [{ "options": { "0": { "color": "green", "text": "UP" }, "1": { "color": "red", "text": "DOWN" } }, "type": "value" }]
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
        "id": 2,
        "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
        "targets": [{ "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "1 - probe_success{job=\"blackbox-att\"}", "legendFormat": "", "refId": "A" }],
        "title": "ATT (VLAN 15)",
        "type": "stat"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0 }, { "color": "red", "value": 1 }] },
            "mappings": [
              { "options": { "0": { "color": "green", "text": "Spectrum (Primary)" }, "1": { "color": "yellow", "text": "ATT (Failover)" }, "2": { "color": "red", "text": "BOTH DOWN" } }, "type": "value" }
            ]
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
        "id": 3,
        "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "textMode": "auto" },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "(1 - probe_success{job=\"blackbox-spectrum\"}) + 2 * (1 - probe_success{job=\"blackbox-att\"})", "legendFormat": "", "refId": "A" }
        ],
        "title": "Active Connection",
        "type": "stat"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
          },
          "overrides": []
        },
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
        "id": 4,
        "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "auto" },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_duration_seconds{job=\"blackbox-spectrum\"} * 1000", "legendFormat": "Spectrum", "refId": "A" },
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_duration_seconds{job=\"blackbox-att\"} * 1000", "legendFormat": "ATT", "refId": "B" }
        ],
        "title": "Latency (ms)",
        "type": "stat"
      },
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
        "id": 101,
        "title": "Latency History",
        "type": "row"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "Latency (ms)", "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": true, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
          },
          "overrides": []
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
        "id": 5,
        "options": { "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_duration_seconds{job=\"blackbox-spectrum\"} * 1000", "legendFormat": "Spectrum (VLAN 1)", "refId": "A" },
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_duration_seconds{job=\"blackbox-att\"} * 1000", "legendFormat": "ATT (VLAN 15)", "refId": "B" }
        ],
        "title": "Ping Latency Over Time",
        "type": "timeseries"
      },
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
        "id": 102,
        "title": "Uptime",
        "type": "row"
      },
      {
        "datasource": { "type": "prometheus", "uid": "prom-ds" },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisColorMode": "text", "drawStyle": "line", "lineInterpolation": "step", "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "off" } },
            "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }],
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
          },
          "overrides": []
        },
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
        "id": 6,
        "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
        "targets": [
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_success{job=\"blackbox-spectrum\"}", "legendFormat": "Spectrum (VLAN 1)", "refId": "A" },
          { "datasource": { "type": "prometheus", "uid": "prom-ds" }, "expr": "probe_success{job=\"blackbox-att\"}", "legendFormat": "ATT (VLAN 15)", "refId": "B" }
        ],
        "title": "Connection Uptime",
        "type": "timeseries"
      }
    ],
    "refresh": "30s",
    "tags": ["network", "ping", "failover"],
    "templating": { "list": [] },
    "time": { "from": "now-24h", "to": "now" },
    "timepicker": {},
    "timezone": "browser",
    "title": "Internet Connection Monitor",
    "uid": "connection-monitor",
    "version": 1
  }
}
