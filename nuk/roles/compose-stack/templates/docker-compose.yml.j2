# Nuk System - Docker Compose Stack
# Generated by Ansible

services:
  grafana:
    image: {{ grafana_image }}
    container_name: grafana
    restart: unless-stopped
    volumes:
      - {{ data_dir }}/grafana/data:/var/lib/grafana
      - {{ data_dir }}/grafana/data/grafana.ini:/etc/grafana/grafana.ini:ro
      - {{ data_dir }}/grafana/data/grafana-provisioning:/etc/grafana/provisioning:ro
    environment:
      - GF_SECURITY_ADMIN_USER={{ grafana_admin_user }}
      - GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}
      - GF_INSTALL_PLUGINS={{ grafana_install_plugins }}
    networks:
      - stack

  prometheus:
    image: {{ prometheus_image }}
    container_name: prometheus
    restart: unless-stopped
    volumes:
      - {{ data_dir }}/prometheus/data:/prometheus
      - {{ data_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ prom_retention }}"
      - "--web.enable-lifecycle"
    networks:
      - stack

  loki:
    image: {{ loki_image }}
    container_name: loki
    restart: unless-stopped
    volumes:
      - {{ data_dir }}/loki/data:/loki
      - {{ data_dir }}/loki/loki-config.yaml:/etc/loki/loki-config.yaml:ro
    command:
      - "--config.file=/etc/loki/loki-config.yaml"
    networks:
      - stack

  promtail:
    image: grafana/promtail:latest
    container_name: promtail
    restart: unless-stopped
    volumes:
      - {{ data_dir }}/promtail/data:/tmp/promtail
      - {{ data_dir }}/promtail/config.yaml:/etc/promtail/config.yaml:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /data0/syslog:/data0/syslog:ro
    command:
      - "--config.file=/etc/promtail/config.yaml"
    networks:
      - stack

  fluent-bit:
    image: {{ fluent_bit_image }}
    container_name: fluent-bit
    restart: unless-stopped
    # Syslog ports not published — rsyslogd owns port 514 on the host
    # Use /data0/syslog volume or network-level forwarding for device logs
    volumes:
      - {{ data_dir }}/fluent-bit/fluent-bit.conf:/fluent-bit/etc/fluent-bit.conf:ro
      - {{ data_dir }}/fluent-bit/parsers.conf:/fluent-bit/etc/parsers.conf:ro
    networks:
      - stack

  uptime-kuma:
    image: {{ uptime_kuma_image }}
    container_name: uptime-kuma
    restart: unless-stopped
    volumes:
      - {{ data_dir }}/uptime-kuma/data:/app/data
    networks:
      - stack

  node-exporter:
    image: {{ node_exporter_image }}
    container_name: node-exporter
    restart: unless-stopped
    volumes:
      - /:/host:ro,rslave
    command:
      - "--path.rootfs=/host"
    networks:
      - stack
    pid: host

  # ── Nginx Reverse Proxy ──────────────────────────────────────
  nginx:
    image: nginx:latest
    container_name: nginx
    restart: unless-stopped
    ports:
      - "80:80"
    volumes:
      - {{ nginx_data_dir }}/config/nginx.conf:/etc/nginx/nginx.conf:ro
      - {{ nginx_data_dir }}/data:/usr/share/nginx/html:ro
      - {{ nginx_data_dir }}/logs:/var/log/nginx
    depends_on:
      - grafana
      - prometheus
      - loki
      - uptime-kuma
      - node-exporter
    networks:
      - stack

  # ── Certbot — SSL Certificate Management ─────────────────────
  # Disabled until DNS points to this host and port 80/443 are open
  # certbot:
  #   image: certbot/certbot:latest
  #   container_name: certbot
  #   volumes:
  #     - /etc/letsencrypt:/etc/letsencrypt
  #     - {{ nginx_data_dir }}/data:/var/www/certbot:ro
  #   entrypoint: "/bin/sh -c 'trap exit TERM; while :; do certbot renew; sleep 12h & wait $${!}; done;'"
  #   restart: unless-stopped

networks:
  stack:
    driver: bridge
